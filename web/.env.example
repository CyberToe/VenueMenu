# Neon / Postgres (use Neon’s pooled URL on Vercel; add pgbouncer if Prisma warns about prepared statements)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"

# Auth.js — generate: openssl rand -base64 32 (required in production)
AUTH_SECRET="replace-with-random-string"

# Canonical site URL — MUST match how users open the app (no trailing slash)
# Local:
# AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"
# Vercel (use your real hostname; both are often required for older tooling):
# AUTH_URL="https://your-project.vercel.app"
# NEXTAUTH_URL="https://your-project.vercel.app"

AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Mapbox (public token for map + geocoding in browser)
NEXT_PUBLIC_MAPBOX_TOKEN="pk...."
